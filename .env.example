# Copy to .env (gitignored) and fill in. Secrets never go in code (constitution §V).

# App
NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgres://offers:offers@localhost:5432/offers

# Redis (queues + rate budget)
REDIS_URL=redis://localhost:6379

# AUTO.RIA official API (developers.ria.com)
AUTO_RIA_API_KEY=

# Telegram bot (@BotFather)
TELEGRAM_BOT_TOKEN=

# Currency (NBU exchange rates)
NBU_RATE_URL=https://bank.gov.ua/NBUStatService/v1/statdirectory/exchange?json

# Rate budget & valuation defaults (tunable per profile)
RATE_BUDGET_PER_HOUR=30
DEFAULT_DISCOUNT_THRESHOLD_PCT=15
DEFAULT_CONFIDENCE_MIN_SAMPLES=10
