# Copy to .env (gitignored) and fill in. Secrets never go in code (constitution §V).

# App
NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgres://offers:offers@localhost:5432/offers

# AUTO.RIA official API (developers.ria.com)
AUTO_RIA_API_KEY=

# Telegram bot (@BotFather)
TELEGRAM_BOT_TOKEN=

# Currency (NBU exchange rates)
NBU_RATE_URL=https://bank.gov.ua/NBUStatService/v1/statdirectory/exchange?json

# Rate budget & valuation defaults (tunable per profile)
RATE_BUDGET_PER_HOUR=30
DEFAULT_MIN_DEAL_SCORE=0.63
DEFAULT_CONFIDENCE_MIN_SAMPLES=10

# Analytic mileage correction (M2) — only used when the cohort wasn't mileage-banded.
# Expected mileage = age × MILEAGE_ANNUAL_K (thousand km/yr); fair value shifts
# MILEAGE_PER_10K_PCT % per 10k km deviation from expected, capped at ±MILEAGE_MAX_ADJ_PCT %.
MILEAGE_ANNUAL_K=15
MILEAGE_PER_10K_PCT=2
MILEAGE_MAX_ADJ_PCT=20

# Structured logging (pino). Level: trace|debug|info|warn|error|fatal.
# Defaults to 'debug' in development, 'info' in production.
LOG_LEVEL=

# Debug: log every outbound request + raw response to external sources (api_key redacted)
LOG_SOURCE_REQUESTS=false

# Auto-calibration (spec 002, E3) — propose by default; set CALIBRATION_MODE=auto for bounded auto-apply
CALIBRATION_MODE=propose
CALIBRATION_MIN_VOLUME=5
CALIBRATION_MAX_VOLUME=20
CALIBRATION_MIN_PRECISION=0.7
