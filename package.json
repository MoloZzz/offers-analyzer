{
  "name": "offers-analyzer",
  "version": "0.1.0",
  "description": "Monitor AUTO.RIA niches and alert on profitable car listings via Telegram",
  "author": "MoloZzz",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings 0",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:contract": "jest --config ./test/jest-contract.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/common/database/data-source.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/common/database/data-source.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/common/database/data-source.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^4.1.0",
    "bullmq": "^5.12.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.4.1",
    "nestjs-telegraf": "^2.9.1",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "telegraf": "^4.16.3",
    "typeorm": "^0.3.20",
    "undici": "^6.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "nock": "^13.5.4",
    "prettier": "^3.3.2",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.3"
  }
}
